#!/usr/bin/env python3
import sys, re, subprocess, difflib, argparse
from datetime import date, datetime, timedelta

JACCARD_THRESHOLD = 0.7
PREFIX_THRESHOLD  = 0.7

_SEP_RE = re.compile(r' [-–—] ')  # hyphen, en-dash, em-dash

def strip_section_suffix(s):
    """Remove trailing ' – ...' only when the dash is outside of [...] brackets."""
    depth = 0
    for i, c in enumerate(s):
        if c == '[':
            depth += 1
        elif c == ']':
            depth = max(0, depth - 1)
        elif depth == 0 and c == ' ' and _SEP_RE.match(s, i):
            return s[:i].strip()
    return s.strip()

# Statuses hidden when -I is active
DEFAULT_IGNORE   = {'x', '-', '&', '»', '«'}
# Project items are structural — always excluded from all output
PROJECT_STATUSES = {'p', 'i', 'u'}

# Dedup priority: when a task appears multiple times in a file, the status with
# the highest priority wins. Ties break by document order (latest wins).
STATUS_PRIORITY = {
    'x': 5,                                                 # done (sticky)
    '-': 4,                                                 # cancelled
    '!': 3, '*': 3, ' ': 3, '#': 3,                         # urgent, important, no-status, blocked
    '/': 2,                                                 # partial
    '&': 1, '«': 1, '»': 1, '>': 1, '=': 1, '~': 1,         # intra-day markers
}

WIKILINK_RE = re.compile(r'\[\[([^\[\]]+)\]\]')

def _strip_wiki_path(m):
    inner = m.group(1)
    if '|' in inner:
        target, alias = inner.split('|', 1)
        return f'[[{target.rsplit("/", 1)[-1]}|{alias}]]'
    return f'[[{inner.rsplit("/", 1)[-1]}]]'

def normalize_wikilinks(s):
    return WIKILINK_RE.sub(_strip_wiki_path, s)

_PUNCT = ',.;:!?-—…'

def _tokens(s):
    out = []
    for t in s.split():
        t = t.lower().strip(_PUNCT)
        if t:
            out.append(t)
    return out

def is_same_task(a, b):
    """Predicate: same logical task. Token-set equality, or strict subset sharing first word."""
    ta, tb = _tokens(a), _tokens(b)
    sa, sb = set(ta), set(tb)
    if not sa or not sb:
        return a == b
    if sa == sb:
        return True
    if (sa < sb or sb < sa) and ta and tb and ta[0] == tb[0]:
        return True
    return False

def _parse_obsidian(file_path, day_index):
    """Yield (base, status, day_index) records from one obsidian file path."""
    result = subprocess.run(
        f"obsidian tasks file='{file_path}' | rg -Fv '#routine'",
        shell=True, capture_output=True, text=True
    )
    for line in result.stdout.splitlines():
        m = re.match(r'^- (\[.\]) (.+)$', line.rstrip())
        if not m:
            continue
        status, full_name = m.group(1), m.group(2)
        full_name = full_name.replace('\\[', '[').replace('\\]', ']')
        full_name = normalize_wikilinks(full_name)
        base = strip_section_suffix(full_name)
        base = re.sub(r'^\(new\)\s*', '', base, flags=re.IGNORECASE)
        yield base, status, day_index

def _parse_lines(d, day_index):
    """Yield (base, status, day_index) records from one daily note."""
    yield from _parse_obsidian(f'01 Daily/{d}', day_index)

def _parse_weekly_file(week_label, day_index):
    """Yield (base, status, day_index) records from one weekly planning file."""
    yield from _parse_obsidian(f'02 Weekly/{week_label}', day_index)

def cluster_records(records):
    """Cluster records by is_same_task using union-find. Returns list of clusters
    (each a list of records) in first-seen order of their root base."""
    bases_in_order, seen = [], set()
    for base, _, _ in records:
        if base not in seen:
            seen.add(base)
            bases_in_order.append(base)

    parent = {b: b for b in bases_in_order}
    def find(x):
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x
    def union(a, b):
        ra, rb = find(a), find(b)
        if ra != rb:
            parent[ra] = rb

    for i, a in enumerate(bases_in_order):
        for b in bases_in_order[i + 1:]:
            if is_same_task(a, b):
                union(a, b)

    by_root = {}
    for rec in records:
        by_root.setdefault(find(rec[0]), []).append(rec)

    clusters, emitted = [], set()
    for b in bases_in_order:
        r = find(b)
        if r in emitted:
            continue
        emitted.add(r)
        clusters.append(by_root[r])
    return clusters

def materialize(clusters):
    """Reduce each cluster to one (canonical_base, winning_status) pair."""
    tasks, order, occurrences = {}, [], {}
    for members in clusters:
        # Canonical: most recent day; tie-break by longest base.
        canonical = max(members, key=lambda r: (r[2], len(r[0])))[0]
        # Winning status: highest STATUS_PRIORITY; tie-break by latest day.
        winning = max(members, key=lambda r: (r[2], STATUS_PRIORITY.get(r[1][1], 0)))[1]
        order.append(canonical)
        tasks[canonical] = winning
        occurrences[canonical] = [s for _, s, _ in members]
    return tasks, order, occurrences

def fetch(d):
    return materialize(cluster_records(list(_parse_lines(d, 0))))

def week_span(d):
    """Return (sunday, saturday, label) for the US-format Sun-Sat week containing d."""
    if isinstance(d, str):
        d = date.fromisoformat(d)
    days_back = (d.weekday() + 1) % 7   # Mon=0..Sun=6 -> Sun=0
    sun = d - timedelta(days=days_back)
    sat = sun + timedelta(days=6)
    jan1 = date(sun.year, 1, 1)
    days_back = 0 if jan1.isoweekday() == 7 else jan1.isoweekday()
    week_num = ((sun - jan1).days + days_back) // 7 + 1
    return sun, sat, f"{sun.year}-W{week_num:02d}"

def week_records(sunday, exclude=None, exclude_weekly_file=False):
    """Gather raw (base, status, day_index) records for a Sun-Sat week, without materializing.
    `exclude` (ISO date string): skip that day. `exclude_weekly_file`: omit the weekly file."""
    _, _, week_label = week_span(sunday)
    records = []
    for i in range(7):
        d = (sunday + timedelta(days=i)).isoformat()
        if d == exclude:
            continue
        records.extend(_parse_lines(d, i))
    if not exclude_weekly_file:
        records.extend(_parse_weekly_file(week_label, day_index=0))
    return records

def fetch_week(sunday, exclude=None, exclude_weekly_file=False):
    """Group 7 daily notes Sun..Sat plus weekly planning file into one virtual note."""
    return materialize(cluster_records(week_records(sunday, exclude, exclude_weekly_file)))

def fetch_weekly_file(week_label):
    """Fetch and deduplicate tasks from a single weekly planning file."""
    return materialize(cluster_records(list(_parse_weekly_file(week_label, day_index=0))))

def jaccard(a, b):
    sa, sb = set(a.lower().split()), set(b.lower().split())
    if not sa and not sb:
        return 1.0
    return len(sa & sb) / len(sa | sb)

def prefix_sim(a, b):
    matcher = difflib.SequenceMatcher(None, a.lower(), b.lower())
    blocks = matcher.get_matching_blocks()
    if not blocks:
        return 0.0
    first = blocks[0]
    if first.a != 0 or first.b != 0:
        return 0.0
    return (2 * first.size) / (len(a) + len(b))

def best_match(name, candidates):
    best, best_score = None, 0
    for c in candidates:
        j = jaccard(name, c)
        p = prefix_sim(name, c)
        score = max(j, p)
        if score > best_score:
            best, best_score = c, score
    if best and best_score >= JACCARD_THRESHOLD:
        return best
    return None

# ── Argument parsing ──────────────────────────────────────────────────────────

parser = argparse.ArgumentParser(
    prog='tdiff',
    description='Compare tasks between two Obsidian daily notes.',
    epilog=(
        'Dates accept YYYY-MM-DD, "today", "yesterday", "0" (today), -N (e.g. -1 for yesterday), '
        'or w## / w2026-W## for a weekly planning file (e.g. w20 = week 20 of the current year). '
        'Use -o N to compare the anchor with anchor + N days; N may be negative.'
    ),
)
parser.add_argument('date_a', help='first (older) date')
parser.add_argument('date_b', nargs='?', default=None, help='second (newer) date (omit with --dupes)')
parser.add_argument('-d', '--deleted',    action='store_true', help='show deleted tasks')
parser.add_argument('-a', '--added',      action='store_true', help='show added tasks')
parser.add_argument('-c', '--changed',    action='store_true', help='show changed tasks')
parser.add_argument('-s', '--same',       action='store_true', help='show unchanged tasks')
parser.add_argument('-D', '--dupes',      action='store_true', help='find duplicate tasks in a single date')
parser.add_argument('-I', '--ignore',     action='store_true',
                    help='hide terminal-status tasks (done, cancelled, overrun, postponed, advanced) '
                         'on the A side (deleted/unchanged rows); added and changed rows are always shown')
parser.add_argument('-o', '--offset',     type=str, default=None,
                    help='compare anchor (date_a) with date_a + N days; N may be negative')
parser.add_argument('-S', '--status',     type=str, default=None,
                    help="show only rows whose effective status is in the given set "
                         "(concatenated chars, e.g. 'x-#'); prefix '^' to invert (e.g. '^x'). "
                         "Bare '-S -' looks like a flag to argparse; use -S=- or quote in a set ('x-')")
parser.add_argument('-w', '--week-offset', type=str, default=None,
                    help='compare anchor (date_a) with the Sun-Sat week N weeks away; N is any integer (negative, 0, or positive)')
parser.add_argument('-W', '--no-weekly',  action='store_true',
                    help='exclude the 02 Weekly/YYYY-W## planning file from -w/-F aggregation')
parser.add_argument('-F', '--full-week',  action='store_true',
                    help='expand day/weekly-file arguments to their full Sun-Sat week aggregation before comparing')
parser.add_argument('--no-color',         action='store_true', help='disable colored output')
parser.add_argument('--no-summary',       action='store_true', help='suppress the summary line')

# argparse chokes on bare negative numbers like -1 before we can process them;
# intercept them and turn them into a safe token first.
raw = sys.argv[1:]
safe = [('__NEG__' + a[1:]) if re.fullmatch(r'-\d+', a) else a for a in raw]
args = parser.parse_args(safe)

def restore(s):
    if s.startswith('__NEG__'):
        return '-' + s[7:]
    return s

_ISO_RE       = re.compile(r'\d{4}-\d{2}-\d{2}')
_NEG_RE       = re.compile(r'-(\d+)')
_WEEK_SHORT_RE = re.compile(r'[wW](\d{1,2})$')
_WEEK_FULL_RE  = re.compile(r'[wW](\d{4}-W\d{2})$')

def resolve_date(s):
    if s == 'today' or s == '0':
        return date.today().isoformat()
    if s == 'yesterday':
        return (date.today() - timedelta(days=1)).isoformat()
    m = _NEG_RE.fullmatch(s)
    if m:
        n = int(m.group(1))
        if n < 1:
            parser.error(f"invalid date: {s!r} (use 0 for today)")
        return (date.today() - timedelta(days=n)).isoformat()
    if _ISO_RE.fullmatch(s):
        try:
            return date.fromisoformat(s).isoformat()
        except ValueError:
            parser.error(f"invalid date: {s!r}")
    parser.error(
        f"invalid date: {s!r} "
        f"(expected YYYY-MM-DD, 'today', 'yesterday', '0', '-N', or 'w##')"
    )

def resolve_week_label(s):
    """Return 'YYYY-W##' if s is a w## specifier, else None."""
    m = _WEEK_FULL_RE.fullmatch(s)
    if m:
        return m.group(1)
    m = _WEEK_SHORT_RE.fullmatch(s)
    if m:
        return f'{date.today().year}-W{int(m.group(1)):02d}'
    return None

def _week_label_to_sunday(week_label):
    """Convert 'YYYY-W##' (US convention: week 1 contains Jan 1, weeks start Sunday)."""
    year, week_num = int(week_label[:4]), int(week_label[6:])
    jan1 = date(year, 1, 1)
    days_back = 0 if jan1.isoweekday() == 7 else jan1.isoweekday()
    return jan1 - timedelta(days=days_back) + timedelta(weeks=week_num - 1)

def to_full_week_side(side, exclude_weekly_file=False):
    """Expand a day/weekly_file side into its containing Sun-Sat full-week aggregate.
    Unlike -w 0 mode, no anchor-exclusion is applied — both sides are independent weeks."""
    kind, key = side
    if kind == 'weekly_file':
        sun = _week_label_to_sunday(key)
    elif kind == 'day':
        sun, _, _ = week_span(key)
    else:
        return side
    return ('week', (sun, None, exclude_weekly_file))

offset = None
if args.offset is not None:
    try:
        offset = int(restore(args.offset))
    except ValueError:
        parser.error(f"--offset expects an integer, got {args.offset!r}")

week_offset = None
if args.week_offset is not None:
    try:
        week_offset = int(restore(args.week_offset))
    except ValueError:
        parser.error(f"--week-offset expects an integer, got {args.week_offset!r}")

if args.full_week and offset is not None:
    parser.error("--full-week cannot be combined with --offset")
if args.full_week and week_offset is not None:
    parser.error("--full-week cannot be combined with --week-offset")
if args.no_weekly and args.week_offset is None and not args.full_week:
    parser.error("--no-weekly only applies to -w/--week-offset or -F/--full-week aggregation")

raw_a = restore(args.date_a)
raw_b = restore(args.date_b) if args.date_b is not None else None
week_label_a = resolve_week_label(raw_a)
week_label_b = resolve_week_label(raw_b) if raw_b is not None else None

# side_a / side_b: ('day', date_str) | ('week', (sun, excl_day, excl_wf)) | ('weekly_file', label)
side_a = side_b = None

if offset is not None:
    if week_label_a:
        parser.error("--offset mode does not support week specifiers (w##)")
    if args.date_b is not None:
        parser.error("cannot combine --offset with an explicit date_b")
    if args.dupes:
        parser.error("cannot combine --offset with --dupes")
    if week_offset is not None:
        parser.error("cannot combine --offset with --week-offset")
    if offset == 0:
        parser.error("--offset must be non-zero")
    date_a = resolve_date(raw_a)
    other = (date.fromisoformat(date_a) + timedelta(days=offset)).isoformat()
    # Keep chronological order: anchor first when offset>0, anchor second when <0.
    if offset > 0:
        date_b = other
    else:
        date_b = date_a
        date_a = other
    side_a = ('day', date_a)
    side_b = ('day', date_b)
elif week_offset is not None:
    if args.date_b is not None:
        parser.error("cannot combine --week-offset with an explicit date_b")
    if args.dupes:
        parser.error("cannot combine --week-offset with --dupes")
    # anchor may be a day or a weekly file; both give an anchor day for offset math
    if week_label_a:
        anchor_sun = _week_label_to_sunday(week_label_a)
        anchor_day_str = anchor_sun.isoformat()
        anchor_side = ('weekly_file', week_label_a)
    else:
        date_a = resolve_date(raw_a)
        anchor_day_str = date_a
        anchor_side = ('day', date_a)
    target_day = date.fromisoformat(anchor_day_str) + timedelta(days=week_offset * 7)
    sun, _, _ = week_span(target_day)
    # When week_offset == 0 the anchor is inside the target week; exclude it from
    # the aggregation so the diff is "anchor vs the rest of its week".
    if week_offset == 0:
        if week_label_a:
            # weekly file is the anchor — exclude it from the agg side, keep all daily notes
            week_key = (sun, None, True)
        else:
            # day is the anchor — exclude that day from the agg side
            week_key = (sun, anchor_day_str, args.no_weekly)
    else:
        week_key = (sun, None, args.no_weekly)
    # week_offset <= 0 -> week is older-or-same -> week on left, anchor on right.
    # week_offset >  0 -> anchor on left, week on right.
    if week_offset <= 0:
        side_a = ('week', week_key)
        side_b = anchor_side
    else:
        side_a = anchor_side
        side_b = ('week', week_key)
    date_b = sun.isoformat()  # kept for any legacy reference; not used by load()
elif args.date_b is not None:
    side_a = ('weekly_file', week_label_a) if week_label_a else ('day', resolve_date(raw_a))
    side_b = ('weekly_file', week_label_b) if week_label_b else ('day', resolve_date(raw_b))
    date_b = raw_b
    if args.full_week:
        side_a = to_full_week_side(side_a, exclude_weekly_file=args.no_weekly)
        side_b = to_full_week_side(side_b, exclude_weekly_file=args.no_weekly)
        if side_a[1][0] == side_b[1][0]:
            parser.error("both dates fall in the same Sun-Sat week; --full-week comparison would be a no-op")
elif not args.dupes:
    parser.error("date_b is required (or use --dupes, --offset N, or --week-offset N)")
else:
    # dupes mode — anchor may be a day or a weekly file
    date_b = None
    side_a = ('weekly_file', week_label_a) if week_label_a else ('day', resolve_date(raw_a))
    if args.full_week:
        side_a = to_full_week_side(side_a, exclude_weekly_file=args.no_weekly)

ignore_set = PROJECT_STATUSES | (DEFAULT_IGNORE if args.ignore else set())

status_filter = None            # (set_of_chars, negate)
if args.status is not None:
    v = args.status
    negate = v.startswith('^')
    if negate:
        v = v[1:]
    chars = set(v)
    if not chars:
        parser.error("--status expects at least one status char (e.g. 'x-#' or '^x')")
    status_filter = (chars, negate)

def status_match(eff):
    if status_filter is None:
        return True
    chars, negate = status_filter
    return (eff not in chars) if negate else (eff in chars)

# ── Colors ────────────────────────────────────────────────────────────────────

use_color = not args.no_color and sys.stdout.isatty()
RED    = '\033[31m' if use_color else ''
GREEN  = '\033[32m' if use_color else ''
YELLOW = '\033[33m' if use_color else ''
DIM    = '\033[2m'  if use_color else ''
RESET  = '\033[0m'  if use_color else ''

# ── Dupes mode ───────────────────────────────────────────────────────────────

if args.dupes:
    _kind, _key = side_a
    if _kind == 'weekly_file':
        _raw_records = list(_parse_weekly_file(_key, day_index=0))
        _label = _key
    elif _kind == 'week':
        _sun, _exclude_day, _exclude_wf = _key
        _raw_records = week_records(_sun, exclude=_exclude_day, exclude_weekly_file=_exclude_wf)
        _, _, _label = week_span(_sun)
    else:
        _raw_records = list(_parse_lines(_key, 0))
        _label = _key
    clusters = cluster_records(_raw_records)

    found = False
    for members in clusters:
        if len(members) <= 1:
            continue
        winning = max(members, key=lambda r: (r[2], STATUS_PRIORITY.get(r[1][1], 0)))[1]
        if winning[1] in ignore_set:
            continue
        if not status_match(winning[1]):
            continue
        # Group records by base within the cluster
        by_base = {}
        for base, status, _ in members:
            by_base.setdefault(base, []).append(status)
        if not found:
            print(f"{YELLOW}Duplicates:{RESET}")
            found = True
        else:
            print()
        marker = RED if len(by_base) == 1 else YELLOW
        sigil = '!!' if len(by_base) == 1 else '~~'
        for base, sts in by_base.items():
            statuses = ', '.join(sts)
            print(f"  {marker}{sigil} {base}{RESET}  ({len(sts)}×  {statuses})")

    if not found:
        print(f"{DIM}No duplicates found in {_label}.{RESET}")

    sys.exit(0)

# ── Diff ──────────────────────────────────────────────────────────────────────

def load(side):
    kind, key = side
    if kind == 'week':
        sun, exclude_day, exclude_wf = key
        return fetch_week(sun, exclude=exclude_day, exclude_weekly_file=exclude_wf)
    if kind == 'weekly_file':
        return fetch_weekly_file(key)
    return fetch(key)

a_tasks, a_order, _ = load(side_a)
b_tasks, b_order, _ = load(side_b)

a_names = set(a_tasks)
b_names = set(b_tasks)

# Types: 0=deleted, 1=added, 2=changed, 3=same
# Tuples: (sort_key, type, display_string, eff_status_char)
# eff_status_char: B's status for added/changed/same; A's status for deleted.
output = []

used_b = set()
used_a = set()

# Pass 1: exact name matches
for name in a_names & b_names:
    used_a.add(name)
    used_b.add(name)
    if a_tasks[name] != b_tasks[name]:
        eff = b_tasks[name][1]
        output.append((name, 2, f"{YELLOW}~~ {a_tasks[name]} → {b_tasks[name]}  {name}{RESET}", eff))
    else:
        eff = a_tasks[name][1]
        output.append((name, 3, f"{DIM}== {a_tasks[name]}  {name}{RESET}", eff))

# Pass 2: fuzzy match remaining
remaining_a = [n for n in a_order if n not in used_a]
remaining_b = [n for n in b_order if n not in used_b]

for a_name in remaining_a:
    match = best_match(a_name, [n for n in remaining_b if n not in used_b])
    if match:
        used_a.add(a_name)
        used_b.add(match)
        a_s, b_s = a_tasks[a_name], b_tasks[match]
        eff = b_s[1]
        if a_name == match:
            output.append((a_name, 2, f"{YELLOW}~~ {a_s} → {b_s}  {a_name}{RESET}", eff))
        else:
            output.append((a_name, 2, f"{YELLOW}~~ {a_s} {a_name} → {b_s} {match}{RESET}", eff))
    else:
        eff = a_tasks[a_name][1]
        output.append((a_name, 0, f"{RED}-- {a_tasks[a_name]}  {a_name}{RESET}", eff))

for b_name in remaining_b:
    if b_name not in used_b:
        eff = b_tasks[b_name][1]
        output.append((b_name, 1, f"{GREEN}++ {b_tasks[b_name]}  {b_name}{RESET}", eff))

output.sort(key=lambda x: (x[0].lower(), x[1]))

# ── Filter & print ────────────────────────────────────────────────────────────

show_all = not any([args.deleted, args.added, args.changed, args.same])
type_enabled = {0: args.deleted, 1: args.added, 2: args.changed, 3: args.same}

counts = {0: 0, 1: 0, 2: 0, 3: 0}
for _, typ, line, eff in output:
    if eff in PROJECT_STATUSES:          # structural: always excluded, any row
        continue
    if args.ignore and typ in (0, 3) and eff in DEFAULT_IGNORE:
        continue                          # -I: hide only settled A-side (deleted/same) rows
    counts[typ] += 1
    if not status_match(eff):          # -S: show only matching effective statuses (print-only)
        continue
    if show_all:
        if typ != 3:   # hide same by default (legacy behavior)
            print(line)
    elif type_enabled[typ]:
        print(line)

# ── Summary ───────────────────────────────────────────────────────────────────

if not args.no_summary:
    parts = [
        f"{GREEN}{counts[1]} added{RESET}",
        f"{RED}{counts[0]} deleted{RESET}",
        f"{YELLOW}{counts[2]} changed{RESET}",
        f"{DIM}{counts[3]} same{RESET}",
    ]
    print('  ' + f"  {DIM}·{RESET}  ".join(parts))
